generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DrawResult {
  id        Int      @id @default(autoincrement())
  date      DateTime
  game      String
  numbers   String
  createdAt DateTime @default(now())
  winners   WinnerRecord[]

  @@unique([game, date])
}

model SuggestionRun {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  constraints String
  suggestions String
  seed        String?
}

model WinnerRecord {
  id               Int         @id @default(autoincrement())
  signature        String      @unique
  game             String
  category         String
  drawDate         DateTime?
  winnerName       String?
  prizeAmountText  String?
  prizeAmountValue Float?
  currency         String?
  location         String?
  detailUrl        String?
  sourcePage       Int?
  sourceOrder      Int?
  rawText          String
  rawPayload       String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  drawResultId     Int?
  drawResult       DrawResult? @relation(fields: [drawResultId], references: [id], onDelete: SetNull)

  @@index([game, category, drawDate])
  @@index([drawResultId])
}
